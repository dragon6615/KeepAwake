# Normalize line endings: store text as LF in the repo, check out native.
* text=auto

# Source / text files always LF
*.go    text eol=lf
*.mod   text eol=lf
*.sum   text eol=lf
*.md    text eol=lf

# Binary files — never touch line endings
*.exe   binary
*.syso  binary
*.ico   binary
*.png   binary
*.dll   binary
